@model List<ProductWithCategoryViewModel>
@{
    ViewData["Title"] = "ProductListWithCategory";
    Layout = "~/Views/Layout/Index.cshtml";
}
<div class="card">
    <div class="card-body">
        <h4 class="card-title">Ürün Listesi Kategorileri İle</h4>
        <div class="row">
            <div class="col-12">
                <div class="table-responsive">
                    <table id="order-listing" class="table">
                        <thead>
                            <tr>
                                <th>Ürün Adı</th>
                                <th>Stok Sayısı</th>
                                <th>Kategori Adı</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model)
                            {
                                <tr>
                                    <td>@x.ProductName</td>
                                    <td>@x.ProductStock</td>
                                    <td>@x.CategoryName</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


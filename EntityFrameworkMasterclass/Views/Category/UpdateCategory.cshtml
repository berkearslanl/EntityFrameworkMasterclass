@model Category
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="page-header mb-4">
            <h3 class="page-title">Kategori Ekle</h3>
        </div>

        <div class="card shadow-sm rounded-4">
            <div class="card-body p-4">

                <form method="post">
                    <input type="hidden" asp-for="CategoryId" />
                    <input type="hidden" asp-for="CategoryStatus" />
                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label fw-semibold">Kategori Adı</label>
                        <input asp-for="CategoryName" class="form-control form-control-lg rounded-3" />
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Category/CategoryList" class="btn btn-light rounded-3 px-4">Vazgeç</a>
                        <button type="submit" class="btn btn-primary rounded-3 px-4">
                            Kaydet
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>


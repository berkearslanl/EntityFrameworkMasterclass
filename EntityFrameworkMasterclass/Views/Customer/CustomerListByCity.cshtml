@model List<IGrouping<string,Customer>>
@{
    ViewData["Title"] = "CustomerListByCity";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h4 class="mb-0">📍 Şehre Göre Müşteri Listesi</h4>
        </div>

        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-warning text-center">
                    Henüz kayıtlı müşteri bulunmamaktadır.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var cityGroup in Model)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm border-0 rounded-3">
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-primary">
                                        @cityGroup.Key
                                    </span>
                                    <span class="badge bg-secondary">
                                        @cityGroup.Count() Kişi
                                    </span>
                                </div>

                                <div class="card-body">
                                    <ul class="list-group list-group-flush">
                                        @foreach (var customer in cityGroup)
                                        {
                                            <li class="list-group-item d-flex align-items-center">
                                                <i class="bi bi-person-circle me-2 text-primary"></i>
                                                @customer.CustomerName @customer.CustomerSurname
                                            </li>
                                        }
                                    </ul>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>

@model List<CustomerCityGroup>
@{
    ViewData["Title"] = "CustomerByCityCount";
    Layout = "~/Views/Layout/Index.cshtml";

    var totalCustomer = Model.Sum(x => x.CustomerCount);
}

<div class="container mt-4">

    <!-- Başlık -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">
            <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>
            Şehre Göre Müşteri Dağılımı
        </h3>
        <span class="badge bg-dark text-white">
            Toplam Müşteri: @totalCustomer
        </span>
    </div>

    <!-- Kart -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Şehir</th>
                            <th>Müşteri Sayısı</th>
                            <th>Oran</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            var percentage = totalCustomer == 0
                            ? 0
                            : (x.CustomerCount * 100.0 / totalCustomer);

                            <tr>
                                <td>
                                    <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                    @x.City
                                </td>

                                <td class="fw-bold">
                                    @x.CustomerCount
                                </td>

                                <td style="width:35%">
                                    <div class="progress" style="height:18px;">
                                        <div class="progress-bar bg-primary"
                                             role="progressbar"
                                             style="width:@percentage%">
                                            @percentage.ToString("0")%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

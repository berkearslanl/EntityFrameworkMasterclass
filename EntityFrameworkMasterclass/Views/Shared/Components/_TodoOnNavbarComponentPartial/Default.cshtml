@model List<Todo>
@{
    string ikonClass = "";
}
<li class="nav-item dropdown">
    <a class="nav-link count-indicator dropdown-toggle" id="notificationDropdown" href="#" data-toggle="dropdown">
        <i class="fas fa-bell mx-0"></i>
        <span class="count">@ViewBag.todoCount</span>
    </a>
    <div class="dropdown-menu dropdown-menu-right navbar-dropdown preview-list" aria-labelledby="notificationDropdown">
        <a href="/Todo/TodoList" class="dropdown-item">
            <p class="mb-0 font-weight-normal float-left">
                Toplam @ViewBag.todoCount bildiriminiz var.
            </p>
            <span class="badge badge-pill badge-warning float-right">Tümünü Gör</span>
        </a>
        @foreach (var x in Model)
        {
            if (x.Priority=="Birincil")
            {
                ikonClass = "preview-icon bg-danger";
            }
            else if(x.Priority == "İkincil")
            {
                ikonClass = "preview-icon bg-warning";
            }
            else if(x.Priority == "Üçüncül")
            {
                ikonClass = "preview-icon bg-info";
            }
            else if (x.Priority == "Dördüncül")
            {
                ikonClass = "preview-icon bg-success";
            }

            <a class="dropdown-item preview-item">
                <div class="preview-thumbnail">
                    <div class="@ikonClass">
                        <i class="fas fa-exclamation-circle mx-0"></i>
                    </div>
                </div>
                <div class="preview-item-content">
                    <h6 class="preview-subject font-weight-medium">@x.Description</h6>
                    <p class="font-weight-light small-text">
                        @x.Priority
                    </p>
                </div>
            </a>
            <div class="dropdown-divider"></div>
        }
    </div>
</li>
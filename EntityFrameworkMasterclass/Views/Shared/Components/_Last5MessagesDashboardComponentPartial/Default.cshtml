@model List<Message>
<div class="col-12 grid-margin">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">
                <i class="fas fa-envelope"></i>
                Son 5 Mesaj
            </h4>
            <div class="table-responsive">
                <table class="table">
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td class="py-1">
                                    <img src="@x.ImageUrl" alt="profile" class="img-sm rounded-circle" />
                                </td>
                                <td class="font-weight-bold">
                                    @x.NameSurname
                                </td>
                                <td>
                                    <label class="badge badge-light badge-pill">@x.Title</label>
                                </td>
                                <td>
                                    @x.Detail
                                </td>
                                <td>
                                    <i class="fas fa-ellipsis-v"></i>
                                </td>
                            </tr>
                        }
                        
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
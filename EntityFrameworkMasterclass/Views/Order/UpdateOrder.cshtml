@model Order
@{
    ViewData["Title"] = "UpdateOrder";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="page-header mb-4">
            <h3 class="page-title">Sipariş Güncelleme Sayfası</h3>
        </div>

        <div class="card shadow-sm rounded-4">
            <div class="card-body p-4">

                <form method="post">
                    <input type="hidden" asp-for="OrderId" />
                    <input type="hidden" asp-for="OrderDate" />
                    <div class="mb-3">
                        <label asp-for="ProductId" class="form-label fw-semibold">Ürün Seçiniz</label>
                        <select asp-for="ProductId" class="form-control" asp-items="@ViewBag.products" required>
                            <option value="" disabled selected>Bir ürün seçin...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CustomerId" class="form-label fw-semibold">Müşteri Seçiniz</label>
                        <select asp-for="CustomerId" class="form-control" asp-items="@ViewBag.customers" required>
                            <option value="" disabled selected>Bir müşteri seçin...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="OrderCount" class="form-label fw-semibold">Sipariş Adedi</label>
                        <input asp-for="OrderCount" class="form-control form-control-lg rounded-3" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UnitPrice" class="form-label fw-semibold">Birim Fiyatı</label>
                        <input asp-for="UnitPrice" class="form-control form-control-lg rounded-3" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="TotalPrice" class="form-label fw-semibold">Toplam Fiyat</label>
                        <input asp-for="TotalPrice" class="form-control form-control-lg rounded-3" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-semibold">Ürünün Durumu</label>
                        <input asp-for="Status" class="form-control form-control-lg rounded-3" />
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Order/OrderListAsyncMethod" class="btn btn-light rounded-3 px-4">Vazgeç</a>
                        <button type="submit" class="btn btn-primary rounded-3 px-4">
                            Siparişi Güncelle
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>





@model List<Todo>
@{
    ViewData["Title"] = "TodoList";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="container mt-4">

    <!-- ÜST BAŞLIK + EKLE BUTONU -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">📂 Todo Listesi</h3>
    </div>

    <!-- KART -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">

            <div class="table-responsive">
                <table id="order-listing" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Kategori Adı</th>
                            <th>Durum</th>
                            <th>Öncelik</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">#@x.TodoId</td>

                                <td>
                                    <i class="bi bi-tag-fill text-primary me-2"></i>
                                    @x.Description
                                </td>

                                <td>
                                    @if (x.Status == true)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2">
                                            <i class="bi bi-check-circle me-1"></i> Yapıldı
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                            <i class="bi bi-pause-circle me-1"></i> Yapılmadı
                                        </span>
                                    }
                                </td>
                                <td>@x.Priority</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

